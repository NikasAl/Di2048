# ============================================================
# RELEASE SIGNING CONFIGURATION TEMPLATE
# ============================================================
#
# Copy this file to 'android/keystore.properties' (NOT 'keystore.properties.example')
# and fill in your real values. The real keystore.properties is in .gitignore
# and MUST NOT be committed — anyone with your keystore + passwords can sign
# updates to your app under your developer identity.
#
# How to generate a new keystore (one-time setup, ~5 minutes):
# ----------------------------------------------------------------
#
# 1. Generate a keystore with keytool (ships with any JDK):
#
#      keytool -genkeypair \
#              -v \
#              -keystore di2048.keystore \
#              -alias di2048 \
#              -keyalg RSA \
#              -keysize 2048 \
#              -validity 10000 \
#              -storepass YOUR_STORE_PASSWORD \
#              -keypass YOUR_KEY_PASSWORD \
#              -dname "CN=Nikas Al, OU=Mobile, O=Electronikas, L=Saratov, ST=Saratov, C=RU"
#
#    Replace YOUR_STORE_PASSWORD and YOUR_KEY_PASSWORD with strong passwords
#    (>= 12 chars, mix of upper/lower/digits/symbols). Write them down in a
#    password manager — losing them means you CANNOT publish updates to the
#    same app listing in Google Play / RuStore ever again.
#
# 2. Move the keystore file somewhere safe (NOT inside the repo).
#    Recommended location: ~/keystores/di2048.keystore
#    The path goes into 'storeFile' below — can be absolute or relative
#    to the android/ module directory.
#
# 3. Copy this template:
#
#      cp android/keystore.properties.example android/keystore.properties
#
#    Edit android/keystore.properties with your real values (see below).
#
# 4. Verify .gitignore contains 'keystore.properties' (it does — see
#    android/.gitignore). NEVER commit keystore.properties.
#
# 5. Build a signed release APK:
#
#      ./gradlew :android:assembleRelease
#
#    Output: android/build/outputs/apk/release/android-release.apk
#
# 6. Build a signed release AAB (required for Google Play since Aug 2021):
#
#      ./gradlew :android:bundleRelease
#
#    Output: android/build/outputs/bundle/release/android-release.aab
#
# 7. Verify the APK is signed:
#
#      $ANDROID_HOME/build-tools/35.0.0/apksigner verify --verbose \
#              android/build/outputs/apk/release/android-release.apk
#
#    You should see 'Verifies' and 'Signed using v1 scheme: true' (and v2/v3).
#
# ============================================================
# TEMPLATE VALUES — replace with your own
# ============================================================

# Path to the keystore file. Can be:
#   - Absolute: /home/nikas/keystores/di2048.keystore
#   - Relative to android/ module: ../keystores/di2048.keystore
# Below is an example relative path — adjust to your real location.
storeFile=../keystores/di2048.keystore

# Password for the keystore file itself (the -storepass you set in keytool).
storePassword=YOUR_STORE_PASSWORD_HERE

# Alias of the key inside the keystore (the -alias you set in keytool).
keyAlias=di2048

# Password for the key (the -keypass you set in keytool).
# Often the same as storePassword, but can be different.
keyPassword=YOUR_KEY_PASSWORD_HERE
